# ─────────────────────────────────────────────
# BONIFÁCIO – AGENTE IA WhatsApp + CRM
# ─────────────────────────────────────────────

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Business API (Meta)
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_whatsapp_token
WA_VERIFY_TOKEN=your_verify_token_custom_string

# Agendor CRM
AGENDOR_API_TOKEN=your_agendor_token
AGENDOR_FUNNEL_ID=1                    # ID do funil no Agendor
AGENDOR_STAGE_INITIAL=10               # ID da etapa inicial (Ex: "Novo Lead")
AGENDOR_STAGE_QUALIFIED=11             # ID da etapa após qualificação (Ex: "Qualificado")

# Vendedores no Agendor (IDs separados por vírgula, na ordem do rodízio)
# Exemplo: Lívia=5, Luiza=8
AGENDOR_SALESPEOPLE_IDS=5,8

# Servidor
PORT=8000
